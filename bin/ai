#!/bin/bash
set -euo pipefail

WAL_FILE="$HOME/.local/state/ai/wal"
WORKTREE_BASE_DIR="$HOME/work/wt/ai"
AI_CMD="claude"
AI_CMD_RESUME="claude --resume"

session_dir() {
    local ai_session_name="$1"

    if [ -d "$WORKTREE_BASE_DIR/$ai_session_name" ]; then
        echo "$WORKTREE_BASE_DIR/$ai_session_name"
    else
        echo "Session directory for '$ai_session_name' not found." >&2
        exit 1
    fi
}

new_session_dir() {
    local ai_session_name="$1"
    echo "$WORKTREE_BASE_DIR/$ai_session_name"
}

wal_append() {
    if [ ! -f "$WAL_FILE" ]; then
        mkdir -p "$(dirname "$WAL_FILE")"
    fi
    local sess="$1"
    local action="$2"
    local data="$3"
    # shellcheck disable=SC2086,SC2048
    join_by_tab "${sess}" "$(date +%s)" "$action" "$data" >>"$WAL_FILE"
    jq --null-input --compact-output \
        --arg sess "$sess" \
        --arg action "$action" \
        --arg data "$data" \
        ' { session: $sess, timestamp: (now | floor), action: $action, data: $data }' \
        >>"${WAL_FILE}.jsonl"
}

join_by_tab() {
    local IFS=$'\t'
    echo "$*"
}

cmd_switch() {
    # The name of the AI session, not to be confused with a tmux session. This is used to name the tmux window and the directory, worktree, branch.
    local ai_session_name="$1"
    ai_session_dir=$(session_dir "$ai_session_name")

    # If there is a window with the same name, abort.
    # This is to prevent accidentally overwriting an existing session.
    tmux_window=$(_tmux_window_for_session "$ai_session_name")
    if [ -n "$tmux_window" ]; then
        echo "A tmux window with the AI session name '$ai_session_name' is already open."
        exit 1
    fi

    wal_append "$ai_session_name" "SWITCH" "$ai_session_dir"
    _switch "$ai_session_name" "$ai_session_dir"
}

_switch() {
    # The name of the AI session, not to be confused with a tmux session. This is used to name the tmux window and the directory, worktree, branch.
    local ai_session_name="$1"
    ai_session_dir=$(session_dir "$ai_session_name")

    # Check if the AI session can be resumed
    local ai_cmd="$AI_CMD"
    claude_project_dir="$HOME/.claude/projects/$(tr '/.' '--' <<<"$ai_session_dir")"
    if [ -d "$claude_project_dir" ]; then
        echo "Existing Claude session found for '$ai_session_name' found in $claude_project_dir. Resuming session."
        ai_cmd="$AI_CMD_RESUME"
    else
        echo "$claude_project_dir not found. Starting new Claude session for '$ai_session_name'."
    fi

    tmux new-window -c "$ai_session_dir" -n "$ai_session_name"
    tmux set -wq @ai_session 1
    tmux set -wq @ai_session_name "$ai_session_name"

    # Three panes:
    # .0 editor (left)
    # .1 AI CLI (top-right)
    # .2 terminal (bottom-right)

    # Split horizontally, the right pane with have 40% width.
    tmux split-window -h -l "40%" -c "#{pane_current_path}"

    # Split the right pane vertically.
    tmux split-window -v -l "50%" -t 1 -c "#{pane_current_path}"

    tmux select-pane -t 1 # Focus the ai cmd pane
    tmux send-keys -t .1 "$ai_cmd" Enter
    tmux send-keys -t .2 "npm ci" Enter
    tmux send-keys -t .0 "git worktree list" Enter
    tmux send-keys -t .0 "git lgh" Enter
}

cmd_create() {
    # The name of the AI session, not to be confused with a tmux session. This is used to name the tmux window and the directory, worktree, branch.
    local ai_session_name=""
    local issue_ref=""
    while [ $# -gt 0 ]; do
        case "$1" in
        --issue)
            issue_ref="$2"
            shift 2
            ;;
        *)
            ai_session_name="$1"
            shift
            ;;
        esac
    done

    if [ -z "$ai_session_name" ]; then
        echo "Usage: ai create <session_name> [--issue <issue_ref>]" >&2
        exit 1
    fi

    # If there is a window with the same name, abort.
    # This is to prevent accidentally overwriting an existing session.
    tmux_window=$(_tmux_window_for_session "$ai_session_name")
    if [ -n "$tmux_window" ]; then
        echo "A tmux window with the AI session name '$ai_session_name' is already open."
        exit 1
    fi

    # If the directory already exist, abort.
    if [ -d "$WORKTREE_BASE_DIR/$ai_session_name" ]; then
        echo "A directory with the name '$ai_session_name' already exists. Please choose a different name or delete the existing directory."
        exit 1
    fi

    ai_session_dir=$(new_session_dir "$ai_session_name")

    if git rev-parse --verify "$ai_session_name" >/dev/null 2>&1; then
        echo "Branch '$ai_session_name' already exists. Creating worktree from existing branch."
        git worktree add "$ai_session_dir" "$ai_session_name"
    else
        echo "Branch '$ai_session_name' does not exist. Creating new branch and worktree."
        git fetch origin main
        git worktree add -b "$ai_session_name" "$ai_session_dir" origin/main
    fi

    wal_append "$ai_session_name" "CREATE" "$ai_session_dir"

    if [ -n "$issue_ref" ]; then
        _set_issue "$ai_session_name" "$issue_ref"
        wal_append "$ai_session_name" "SET_ISSUE" "$issue_ref"
    fi

    _switch "$ai_session_name"
}

_tmux_window_for_session() {
    local ai_session_name="$1"
    tmux list-windows \
        -f "#{==:#{@ai_session_name},${ai_session_name}}" \
        -F "#{window_id}" 2>/dev/null | head -1
}

_pr_for_session() (
    local ai_session_name="$1"
    ai_session_dir=$(session_dir "$ai_session_name")

    cd "$ai_session_dir"
    set +e
    pr_info=$(gh pr view --json number,state,closed,mergeStateStatus,mergeable,mergedAt,headRefName)
    set -e
    if [ -z "$pr_info" ]; then
        echo '{"number": null, "state": null}'
    else
        wal_append "$ai_session_name" "ADD_PR" "$pr_info"
        echo "$pr_info"
    fi
)

_list_prs() {
    gh pr list \
        --author "@me" \
        --limit 200 \
        "$@" \
        --json number,state,closed,mergeStateStatus,mergeable,headRefName,url \
        --jq '[.[] | . + {ai_mergeable: (.mergeStateStatus == "CLEAN" and .mergeable == "MERGEABLE" and .state == "OPEN")}]' 2>/dev/null || echo '[]'
}

_get_issue() {
    local ai_session_name="$1"
    git config --get "branch.${ai_session_name}.aiIssue" 2>/dev/null || true
}

_set_issue() {
    local ai_session_name="$1"
    local issue_ref="$2"
    git config "branch.${ai_session_name}.aiIssue" "$issue_ref"
}

_clear_issue() {
    local ai_session_name="$1"
    git config --unset "branch.${ai_session_name}.aiIssue" 2>/dev/null || true
}

# Build a URL for the given issue ref. Pass-through if the ref is already a URL.
# Linear workspace is read from $AI_LINEAR_WORKSPACE; without it, we can't build a
# URL and this returns empty.
_linear_url() {
    local ref="$1"
    if [ -z "$ref" ]; then
        return
    fi
    if [[ "$ref" == http* ]]; then
        echo "$ref"
        return
    fi
    if [ -n "${AI_LINEAR_WORKSPACE:-}" ]; then
        echo "https://linear.app/${AI_LINEAR_WORKSPACE}/issue/${ref}"
    fi
}

cmd_rm() {
    local ai_session_name="$1"
    ai_session_dir=$(session_dir "$ai_session_name")

    # If there is a window with the same name, abort.
    tmux_window=$(_tmux_window_for_session "$ai_session_name")
    if [ -n "$tmux_window" ]; then
        echo "A tmux window with the AI session name '$ai_session_name' is open."
        exit 1
    fi

    pr_info=$(_pr_for_session "$ai_session_name")
    if [ "$(jq -r '.number' <<<"$pr_info")" == "null" ]; then
        echo "No PR found for branch '$ai_session_name'. Skipping PR check."
    else
        merged=$(jq '.state == "MERGED" and .closed == true' <<<"$pr_info")
        if [ "$merged" != "true" ]; then
            echo "PR for branch '$ai_session_name' is not merged. Please merge the PR before removing the session."
            echo "PR info: $pr_info"
            exit 1
        fi
    fi
    # TODO: Handle not merged closed PRs?
    # TODO: Add protection so that branchs without PR cannot be removed, to avoid accidentally deleting worktrees with unpushed work.

    wal_append "$ai_session_name" "REMOVE" "$ai_session_dir"

    git worktree remove "$ai_session_dir"
    git branch -d "$ai_session_name" 2>/dev/null
}

cmd_mergeable() (
    prs=$(_list_prs "$@")
    echo "All PRs:"
    jq '.' <<<"$prs"

    echo "Mergeable PRs:"
    jq '.[] | select(.ai_mergeable == true)' <<<"$prs"

    # TODO: Filter PRs related to sessions.
    # TODO: Add select with fzf then continue with cmd_merge for the selected PR
)

cmd_merge() {
    local ai_session_name="$1"
    ai_session_dir=$(session_dir "$ai_session_name")

    # Check if the PR is approved and mergeable.
    pr_info=$(_pr_for_session "$ai_session_name")
    mergeable=$(jq '.mergeStateStatus == "CLEAN" and .mergeable == "MERGEABLE" and .state == "OPEN"' <<<"$pr_info")
    if [ "$mergeable" != "true" ]; then
        echo "PR for branch '$ai_session_name' is not mergeable. Please resolve conflicts and make sure it is approved before merging."
        echo "PR info: $pr_info"
        exit 1
    fi

    # If there is a window with the same name, abort.
    tmux_window=$(_tmux_window_for_session "$ai_session_name")
    if [ -n "$tmux_window" ]; then
        echo "A tmux window with the AI session name '$ai_session_name' is open."
        exit 1
    fi

    # Merge the PR.
    pr_number=$(jq -r '.number' <<<"$pr_info")
    echo "Merging PR #${pr_number} for branch '$ai_session_name'..."

    # After merge the branch will change to the base branch (usually main). This will fail in a woktree context like this:
    # failed to delete local branch <branch name>: failed to run git: error: cannot delete branch '<branch name>' used by worktree at '<worktree path>'
    # This is handled by ignoring the error and then checkin if the pr was merged.
    # TODO: Verify remote branch is deleted?
    gh pr merge --rebase "$ai_session_name" || true

    pr_info=$(_pr_for_session "$ai_session_name")
    if [ "$(jq -r '.number' <<<"$pr_info")" == "null" ]; then
        echo "No PR found for branch '$ai_session_name'. Not expected after merging."
        exit 1
    else
        merged=$(jq '.state == "MERGED" and .closed == true' <<<"$pr_info")
        if [ "$merged" != "true" ]; then
            echo "PR for branch '$ai_session_name' is not merged. Please merge the PR before removing the session."
            echo "PR info: $pr_info"
            exit 1
        fi
    fi

    wal_append "$ai_session_name" "MERGED_PR" "$pr_info"

    git worktree remove "$ai_session_dir"
    git branch -d "$ai_session_name" 2>/dev/null
}

cmd_issue() {
    local ai_session_name="${1:-}"
    if [ -z "$ai_session_name" ]; then
        echo "Usage: ai issue <session_name> [<issue_ref>|--clear]" >&2
        exit 1
    fi

    # Ensure the session exists before touching config.
    session_dir "$ai_session_name" >/dev/null

    if [ "$#" -lt 2 ]; then
        local issue
        issue=$(_get_issue "$ai_session_name")
        if [ -n "$issue" ]; then
            echo "$issue"
        else
            echo "No issue associated with session '$ai_session_name'." >&2
            exit 1
        fi
        return
    fi

    if [ "$2" = "--clear" ]; then
        _clear_issue "$ai_session_name"
        wal_append "$ai_session_name" "CLEAR_ISSUE" ""
        echo "Cleared issue for session '$ai_session_name'."
    else
        _set_issue "$ai_session_name" "$2"
        wal_append "$ai_session_name" "SET_ISSUE" "$2"
        echo "Set issue for session '$ai_session_name' to '$2'."
    fi
}

_collect_list_data() {
    local tmux_windows
    tmux_windows=$(tmux list-windows -f '#{@ai_session}' -F "#{@ai_session_name} #{window_active}" 2>/dev/null || true)

    local pr_data
    pr_data=$(_list_prs --state=all)

    local rows='[]'

    for wt_dir in "$WORKTREE_BASE_DIR"/*/; do
        [ -d "$wt_dir" ] || continue
        local session_name
        session_name=$(basename "$wt_dir")

        # Git info from the worktree HEAD
        local commit_hash="" commit_date=""
        if commit_info=$(git for-each-ref --format='%(objectname:short)@%(committerdate:relative)' "refs/heads/$session_name" 2>/dev/null) && [ -n "$commit_info" ]; then
            IFS='@' read -r commit_hash commit_date <<<"$commit_info"
        fi

        # Tmux window status
        local window_status=""
        if echo "$tmux_windows" | grep -q "^${session_name} "; then
            if echo "$tmux_windows" | grep -q "^${session_name} 1$"; then
                window_status="open (active)"
            else
                window_status="open"
            fi
        fi

        # Claude project dir exists
        local claude_status=""
        local claude_project_dir
        claude_project_dir="$HOME/.claude/projects/$(tr '/.' '--' <<<"${wt_dir%/}")"
        if [ -d "$claude_project_dir" ]; then
            claude_status="yes"
        fi

        # PR info
        local pr_number="" pr_state="" pr_merge_status="" pr_url="" ai_mergeable=""
        local pr_match
        pr_match=$(jq -r --arg branch "$session_name" '.[] | select(.headRefName == $branch) | "\(.number)\t\(.state)\t\(.mergeStateStatus)\t\(.url)\t\(.ai_mergeable)"' <<<"$pr_data")
        if [ -n "$pr_match" ]; then
            IFS=$'\t' read -r pr_number pr_state pr_merge_status pr_url ai_mergeable <<<"$pr_match"
        fi

        # Issue ref (Linear or other tracker) stored in branch config
        local issue_ref="" issue_url=""
        issue_ref=$(_get_issue "$session_name")
        issue_url=$(_linear_url "$issue_ref")

        rows=$(jq --arg session "$session_name" \
            --arg commit "$commit_hash" \
            --arg committed "$commit_date" \
            --arg window "$window_status" \
            --arg claude "$claude_status" \
            --arg issue "$issue_ref" \
            --arg issue_url "$issue_url" \
            --arg pr_number "$pr_number" \
            --arg pr_state "$pr_state" \
            --arg pr_merge_status "$pr_merge_status" \
            --arg pr_url "$pr_url" \
            --argjson ai_mergeable "${ai_mergeable:-false}" \
            '. += [{session: $session, commit: $commit, committed: $committed, window: $window, claude: $claude, issue: $issue, issue_url: $issue_url, pr_number: ($pr_number | if . == "" then null else tonumber end), pr_state: $pr_state, pr_merge_status: $pr_merge_status, pr_url: $pr_url, ai_mergeable: $ai_mergeable}]' <<<"$rows")
    done

    echo "$rows"
}

cmd_list() {
    local json_output=false
    if [ "${1:-}" = "--json" ]; then
        json_output=true
    fi

    local data
    data=$(_collect_list_data)

    if [ "$json_output" = true ]; then
        jq '.' <<<"$data"
        return
    fi

    # Only emit OSC-8 hyperlinks when stdout is a terminal.
    local use_osc8=false
    if [ -t 1 ]; then
        use_osc8=true
    fi

    # Static column widths. Content that overflows its width pushes later
    # columns to the right on that row only; the PR column is unbounded.
    jq -r --argjson osc8 "$use_osc8" '
        def link(url; text):
            if $osc8 and (url // "") != ""
            then "\u001b]8;;\(url)\u0007\(text)\u001b]8;;\u0007"
            else text end;
        def pad(s; w): s + (" " * ([w - (s | length), 0] | max));
        def padlink(visible; wrapped; w): wrapped + (" " * ([w - (visible | length), 0] | max));

        ([pad("SESSION"; 30), pad("COMMIT"; 8), pad("COMMITTED"; 16), pad("WINDOW"; 14), pad("CLAUDE"; 6), pad("ISSUE"; 12), "PR"] | join("  ")),
        (.[] |
          (if .issue == "" then "-" else .issue end) as $issue |
          [ pad(.session; 30),
            pad((.commit // "-"); 8),
            pad((.committed // "-"); 16),
            pad((.window | if . == "" then "-" else . end); 14),
            pad((.claude | if . == "" then "" elif . == "yes" then "✓" else . end); 6),
            padlink($issue; link(.issue_url; $issue); 12),
            (if .pr_number then link(.pr_url; "#\(.pr_number) \(if .ai_mergeable then "✅" else "" end) \(.pr_url)") else "-" end)
          ] | join("  ")
        )
    ' <<<"$data"
}

cmd_help() {
    echo "Usage: ai <command> [options]"
    echo "Commands:"
    echo "  create <session_name> [--issue <ref>]   Create a new AI session. Optionally associate a tracker issue (e.g. Linear ID)."
    echo "  switch <session_name>                   Switch to an existing AI session with the given name."
    echo "  remove <session_name>                   Remove an existing AI session with the given name. This will delete the git branch and worktree if branch is merged."
    echo "  merge <session_name>                    Merge the PR for the given AI session. This will check if the PR is mergeable and then merge it. After merging, the session will be removed."
    echo "  issue <session_name> [<ref>|--clear]    Get, set, or clear the tracker issue ref for the given session."
    echo "  list [--json]                           List existing AI sessions and tmux windows."
    echo "  help                                    Show this help message."
}

if [ "$#" -le 0 ]; then
    cmd_help
    exit 1
fi
while [ "$#" -ge 1 ]; do
    case "$1" in
    --debug)
        set -x
        # shellcheck disable=2034
        DEBUG=true
        shift
        ;;
    create)
        shift
        cmd_create "$@"
        break
        ;;
    switch)
        shift
        cmd_switch "$@"
        break
        ;;
    remove)
        shift
        cmd_rm "$@"
        break
        ;;
    merge)
        shift
        cmd_merge "$@"
        break
        ;;
    issue)
        shift
        cmd_issue "$@"
        break
        ;;
    mergeable)
        shift
        cmd_mergeable "$@"
        break
        ;;
    list)
        shift
        cmd_list "$@"
        break
        ;;
    help | *)
        shift
        cmd_help
        break
        ;;
    esac
done
