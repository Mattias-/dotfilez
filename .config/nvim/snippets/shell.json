{
  "argparse": {
    "body": [
      "if [ \"\\$#\" -le 0 ]; then",
      "    cmd_help",
      "    exit 1",
      "fi",
      "while [ \"\\$#\" -ge 1 ]; do",
      "    case \"\\$1\" in",
      "    --debug)",
      "        shift",
      "        set -x",
      "        # shellcheck disable=2034",
      "        DEBUG=true",
      "        ;;",
      "    #cmd)",
      "    #    shift",
      "    #    cmd_action \"\\$@\"",
      "    #    break",
      "    #    ;;",
      "    help | *)",
      "        shift",
      "        cmd_help",
      "        break",
      "        ;;",
      "    esac",
      "done"
    ],
    "prefix": "argparse"
  },
  "echoerr": {
    "body": [
      "echo_err_blue() {",
      "    (",
      "        tput setaf 033",
      "        echo \"\\$@\"",
      "        tput sgr0",
      "    ) 1>&2",
      "}"
    ],
    "prefix": "echoerr"
  },
  "helpfn": {
    "body": "cmd_help() {\n    cat <<EOF\nUsage: $0 COMMAND\nEOF\n}",
    "prefix": "helpfn"
  },
  "mainfn": {
    "body": "main() {\n    ${1:STMT}\n}\n\nmain \"\\$@\"",
    "prefix": "mainfn"
  },
  "scriptdir": {
    "body": [
      "scriptdir() {",
      "    (cd \"\\$(dirname \"\\$(readlink -f \"\\$0\")\")\" && pwd)",
      "}\n${0}"
    ],
    "prefix": "scriptdir"
  },
  "shebang": {
    "body": [
      "#!/bin/bash",
      "set -euo pipefail",
      "",
      "$0"
    ],
    "prefix": "she"
  },
  "trapfn": {
    "body": [
      "finish() {",
      "    :$0",
      "}",
      "trap finish EXIT"
    ],
    "prefix": "trapfn"
  }
}