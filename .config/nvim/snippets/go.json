      "type requestPayload struct {",
      "  Name string `json:\"name\"`",
      "}",
      "var payload requestPayload",
      "if err := json.Unmarshal(bodyBytes, &requestPayloadyload); err != nil {",
      "  http.Error(w, \"invalid JSON payload\", http.StatusBadRequest)",
      "  return",
      "}"
