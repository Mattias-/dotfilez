  },
  "Go HTTP JSON response helper": {
    "prefix": "httpwritejson",
    "body": [
      "type responsePayload struct {",
      "  Bucket     string `json:\"bucket\"`",
      "  ObjectName string `json:\"object_name\"`",
      "  Name       string `json:\"name\"`",
      "}",
      "resData := responsePayload{",
      "  Bucket:     r.PathValue(\"bucket\"),",
      "  ObjectName: r.PathValue(\"objectname\"),",
      "  Name:       payload.Name,",
      "}",
      "resDataBytes, err := json.Marshal(resData)",
      "if err != nil {",
      "  http.Error(w, \"failed to marshal response\", http.StatusInternalServerError)",
      "  return",
      "}",
      "w.Header().Set(\"Content-Type\", \"application/json; charset=utf-8\")",
      "w.WriteHeader(http.StatusOK)",
      "if _, err := w.Write(resDataBytes); err != nil {",
      "  slog.Error(\"failed to write response\", \"err\", err)",
      "}"
    ],
    "description": "Write JSON response helper for handlers"
  },
  "Go HTTP middleware template": {
    "prefix": "httpmw",
    "body": [
      "func loggingMiddleware(next http.Handler) http.Handler {",
      "  return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {",
      "    start := time.Now()",
      "    next.ServeHTTP(w, r)",
      "    slog.Info(\"request\",",
      "      \"method\", r.Method,",
      "      \"path\", r.URL.Path,",
      "      \"pattern\", r.Pattern,",
      "      \"duration\", time.Since(start),",
      "    )",
      "  })",
      "}"
    ],
    "description": "HTTP middleware skeleton with request logging"
  },
  "Go HTTP middleware updating request context": {
    "prefix": "httpmwctx",
    "body": [
      "type ctxKeyRequestID int",
      "",
      "const requestIDKey ctxKeyRequestID = 0",
      "",
      "func requestIdMiddleware(next http.Handler) http.Handler {",
      "	const requestIDHeader = \"X-Request-Id\"",
      "",
      "	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {",
      "		ctx := r.Context()",
      "		requestID := r.Header.Get(requestIDHeader)",
      "		if requestID == \"\" {",
      "			requestID = \"placeholder\" // TODO: generate request ID, e.g. using uuid.NewString()",
      "		}",
      "		newCtx := context.WithValue(ctx, requestIDKey, requestID)",
      "		next.ServeHTTP(w, r.WithContext(newCtx))",
      "	})",
      "}",
      "",
      "func getReqID(ctx context.Context) string {",
      "	if ctx == nil {",
      "		return \"\"",
      "	}",
      "	if reqID, ok := ctx.Value(requestIDKey).(string); ok {",
      "		return reqID",
      "	}",
      "	return \"\"",
      "}"
    ],
    "description": "HTTP middleware skeleton that adds user ID from header to request context"
  },
  "Go HTTP handler test (httptest)": {
    "prefix": "httptesthandler",
    "body": [
      "func TestHandler(t *testing.T) {",
      "	t.Parallel()",
      "",
      "	{",
      "		body := \"\"",
      "		req := httptest.NewRequest(http.MethodGet, \"/\", strings.NewReader(body))",
      "		req.SetPathValue(\"bucket\", \"bb\")",
      "		req.SetPathValue(\"objectname\", \"hello/world\")",
      "		rr := httptest.NewRecorder()",
      "",
      "		handler(rr, req)",
      "",
      "		if rr.Code != http.StatusBadRequest {",
      "			t.Fatalf(\"expected status %d, got %d\", http.StatusBadRequest, rr.Code)",
      "		}",
      "	}",
      "",
      "	{",
      "		body := []byte(`{\"name\": \"test\"}`)",
      "		req := httptest.NewRequest(http.MethodGet, \"/\", bytes.NewReader(body))",
      "		req.SetPathValue(\"bucket\", \"bb\")",
      "		req.SetPathValue(\"objectname\", \"hello/world\")",
      "		rr := httptest.NewRecorder()",
      "",
      "		handler(rr, req)",
      "",
      "		if rr.Code != http.StatusOK {",
      "			t.Fatalf(\"expected status %d, got %d\", http.StatusOK, rr.Code)",
      "		}",
      "		if rr.Body.String() != `{\"bucket\":\"bb\",\"object_name\":\"hello/world\",\"name\":\"test\"}` {",
      "			t.Fatalf(\"expected body 'ok', got '%s'\", rr.Body.String())",
      "		}",
      "		if rr.Result().Header.Get(\"Content-Type\") != \"application/json; charset=utf-8\" {",
      "			t.Fatalf(\"expected Content-Type 'application/json', got '%s'\", rr.Result().Header.Get(\"Content-Type\"))",
      "		}",
      "		if len(rr.Result().Cookies()) > 0 {",
      "			t.Fatalf(\"expected no cookies, got %v\", rr.Result().Cookies())",
      "		}",
      "	}",
      "}"
    ],
    "description": "Table-free starter test for a handler"
  },
  "Go HTTP handler test (httptest)": {
    "prefix": "httptestservemux",
    "body": [
      "func TestRouter(t *testing.T) {",
      "	t.Parallel()",
      "",
      "	mux := router()",
      "",
      "	{",
      "		body := \"\"",
      "		req := httptest.NewRequest(http.MethodPost, \"/b/bb/hello/world\", strings.NewReader(body))",
      "		rr := httptest.NewRecorder()",
      "",
      "		mux.ServeHTTP(rr, req)",
