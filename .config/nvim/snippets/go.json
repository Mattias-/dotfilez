      "		if rr.Code != http.StatusOK {",
      "			t.Fatalf(\"expected status %d, got %d\", http.StatusOK, rr.Code)",
      "		}",
      "		if rr.Body.String() != `{\"bucket\":\"bb\",\"object_name\":\"hello/world\",\"name\":\"test\"}` {",
      "			t.Fatalf(\"expected body 'ok', got '%s'\", rr.Body.String())",
      "		}",
      "		if rr.Result().Header.Get(\"Content-Type\") != \"application/json; charset=utf-8\" {",
      "			t.Fatalf(\"expected Content-Type 'application/json', got '%s'\", rr.Result().Header.Get(\"Content-Type\"))",
      "		}",
      "		if len(rr.Result().Cookies()) > 0 {",
      "			t.Fatalf(\"expected no cookies, got %v\", rr.Result().Cookies())",
      "		}",
      "	}",
      "}"
    ]
