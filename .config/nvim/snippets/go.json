  "Go HTTP JSON response helper": {
    "body": [
      "type responsePayload struct {",
      "  Bucket     string `json:\"bucket\"`",
      "  ObjectName string `json:\"object_name\"`",
      "  Name       string `json:\"name\"`",
      "}",
      "resData := responsePayload{",
      "  Bucket:     r.PathValue(\"bucket\"),",
      "  ObjectName: r.PathValue(\"objectname\"),",
      "  Name:       payload.Name,",
      "}",
      "resDataBytes, err := json.Marshal(resData)",
      "if err != nil {",
      "  http.Error(w, \"failed to marshal response\", http.StatusInternalServerError)",
      "  return",
      "}",
      "w.Header().Set(\"Content-Type\", \"application/json; charset=utf-8\")",
      "w.WriteHeader(http.StatusOK)",
      "if _, err := w.Write(resDataBytes); err != nil {",
      "  slog.Error(\"failed to write response\", \"err\", err)",
      "}"
    ],
    "description": "Write JSON response helper for handlers",
    "prefix": "httpwritejson"
  },
  "Go HTTP handler function": {
    "body": [
      "func handler(w http.ResponseWriter, r *http.Request) {",
      "  if r.Method != http.MethodGet {",
      "    http.Error(w, \"method not allowed\", http.StatusMethodNotAllowed)",
      "    return",
      "  }",
      "",
      "  w.Header().Set(\"Content-Type\", \"text/plain; charset=utf-8\")",
      "  w.WriteHeader(http.StatusOK)",
      "  _, _ = fmt.Fprintf(w, \"ok\")",
      "}"
    ],
    "description": "Basic standalone HTTP handler function",
    "prefix": "httphandlerfn"
  },
