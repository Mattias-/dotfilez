  "Go HTTP middleware template": {
    "body": [
      "func loggingMiddleware(next http.Handler) http.Handler {",
      "  return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {",
      "    start := time.Now()",
      "    next.ServeHTTP(w, r)",
      "    slog.Info(\"request\",",
      "      \"method\", r.Method,",
      "      \"path\", r.URL.Path,",
      "      \"pattern\", r.Pattern,",
      "      \"duration\", time.Since(start),",
      "    )",
      "  })",
      "}"
    ],
    "description": "HTTP middleware skeleton with request logging",
    "prefix": "httpmw"
  },
  "Go HTTP middleware updating request context": {
    "body": [
      "type ctxKeyRequestID int",
      "",
      "const requestIDKey ctxKeyRequestID = 0",
      "",
      "func requestIdMiddleware(next http.Handler) http.Handler {",
      "\tconst requestIDHeader = \"X-Request-Id\"",
      "",
      "\treturn http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {",
      "\t\tctx := r.Context()",
      "\t\trequestID := r.Header.Get(requestIDHeader)",
      "\t\tif requestID == \"\" {",
      "\t\t\trequestID = \"placeholder\" // TODO: generate request ID, e.g. using uuid.NewString()",
      "\t\t}",
      "\t\tnewCtx := context.WithValue(ctx, requestIDKey, requestID)",
      "\t\tnext.ServeHTTP(w, r.WithContext(newCtx))",
      "\t})",
      "}",
      "",
      "func getReqID(ctx context.Context) string {",
      "\tif ctx == nil {",
      "\t\treturn \"\"",
      "\t}",
      "\tif reqID, ok := ctx.Value(requestIDKey).(string); ok {",
      "\t\treturn reqID",
      "\t}",
      "\treturn \"\"",
      "}"
    ],
    "description": "HTTP middleware skeleton that adds user ID from header to request context",
    "prefix": "httpmwctx"
  },
  "Go HTTP server main (ServeMux + graceful shutdown)": {
    "body": [
      "package main",
      "",
      "import (",
      "  \"context\"",
      "  \"errors\"",
      "  \"log/slog\"",
      "  \"net/http\"",
      "  \"os\"",
      "  \"os/signal\"",
      "  \"syscall\"",
      "  \"time\"",
      ")",
      "",
      "func main() {",
      "  slog.SetDefault(slog.New(slog.NewJSONHandler(os.Stderr, nil)))",
      "  mux := http.NewServeMux()",
      "  mux.HandleFunc(\"GET /{\\$}\", func(w http.ResponseWriter, r *http.Request) {",
      "    w.WriteHeader(http.StatusOK)",
      "    _, _ = w.Write([]byte(\"Hello, World!\"))",
      "  })",
      "  mux.HandleFunc(\"GET /handler\", nil)",
      "",
      "  srv := &http.Server{",
      "    Addr:              \":8080\",",
      "    Handler:           mux,",
      "    ReadHeaderTimeout: 5 * time.Second,",
      "  }",
      "",
      "  ctx, stop := signal.NotifyContext(context.Background(), os.Interrupt, syscall.SIGTERM)",
      "  defer stop()",
      "",
      "  go func() {",
      "    slog.Info(\"http server starting\", \"addr\", srv.Addr)",
      "    if err := srv.ListenAndServe(); err != nil && !errors.Is(err, http.ErrServerClosed) {",
      "      slog.Error(\"server failed\", \"err\", err)",
      "      os.Exit(1)",
      "    }",
      "  }()",
      "",
      "  <-ctx.Done()",
      "",
      "  shutdownCtx, cancel := context.WithTimeout(context.Background(), 10*time.Second)",
      "  defer cancel()",
      "",
      "  if err := srv.Shutdown(shutdownCtx); err != nil {",
      "    slog.Error(\"graceful shutdown failed\", \"err\", err)",
      "    os.Exit(1)",
      "  }",
      "",
      "  slog.Info(\"server stopped\")",
      "}"
    ],
    "description": "HTTP server with method/path routing and graceful shutdown",
    "prefix": "httpmain"
  },
  "Go ServeMux route patterns showcase": {
    "body": [
      "mux.HandleFunc(\"GET /{\\$}\", nil)",
      "mux.HandleFunc(\"GET /healthz\", nil)",
      "mux.HandleFunc(\"GET /b/{bucket}/{objectname...}\", func(w http.ResponseWriter, r *http.Request) {",
      "  bucket := r.PathValue(\"bucket\")",
      "  _, _ = fmt.Fprintf(w, \"user bucket=%s\", bucket)",
      "})"
    ],
    "description": "Register multiple handlers to demonstrate ServeMux pattern matching",
    "prefix": "muxpatterns"
  },
  "httpjsonerrorresponse": {
    "body": [
      "func jsonErrorResponse(w http.ResponseWriter, statusCode int, message string) {",
      "\t// Response type for rfc7807 problem details",
      "\ttype problemDetails struct {",
      "\t\tType     string `json:\"type,omitempty\"`",
      "\t\tTitle    string `json:\"title,omitempty\"`",
      "\t\tStatus   int    `json:\"status,omitempty\"`",
      "\t\tDetail   string `json:\"detail,omitempty\"`",
      "\t\tInstance string `json:\"instance,omitempty\"`",
      "\t}",
      "\tresDataBytes, err := json.Marshal(problemDetails{",
      "\t\tStatus: statusCode,",
      "\t\tDetail: message,",
      "\t})",
      "\tif err != nil {",
      "\t\thttp.Error(w, \"failed to marshal response\", http.StatusInternalServerError)",
      "\t\treturn",
      "\t}",
      "\tw.Header().Set(\"Content-Type\", \"application/problem+json\")",
      "\tw.WriteHeader(statusCode)",
      "\tif _, err := w.Write(resDataBytes); err != nil {",
      "\t\tslog.Error(\"failed to write response\", \"err\", err)",
      "\t}",
      "}"
    ],
    "prefix": "httpjsonerrorresponse"
  },
